{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyTips",
  "version": "0.1.0",
  "identifier": "com.mytips.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "title": "MyTips",
        "center": true,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "img-src": ["'self'", "https://*"],
        "connect-src": ["'self'", "https://*"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"]
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "dialog": null,
    "global-shortcut": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
